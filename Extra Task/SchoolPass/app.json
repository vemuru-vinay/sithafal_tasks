{
  "expo": {
    "name": "IISER Outing System",
    "slug": "iiser-outing-system",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#1A1714",
      "image": "./assets/icon.png"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.schoolpass.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to scan student outing passes at the campus gate."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1714"
      },
      "package": "com.schoolpass.app",
      "permissions": ["CAMERA", "VIBRATE", "RECEIVE_BOOT_COMPLETED", "INTERNET"]
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "Allow IISER Outing System to access your camera to scan outing passes." }],
      ["expo-notifications", {
        "icon": "./assets/icon.png",
        "color": "#1D4ED8"
      }]
    ]
  }
}
