                {
                    "rowIndex": 2,
                    "Title": "Definitions: ED: Emergency Department"
                },
                {
                    "rowIndex": 4,
                    "Title": "LWBS: Left Without Being Seen. The percentage of patients who check in but leave before being evaluated by a provider."
                },
                {
                    "rowIndex": 6,
                    "Title": "LOS: Length of Stay. The time a patient spends in a specific phase of care."
                },
                {
                    "rowIndex": 8,
                    "Title": "NEDOC: National Emergency Department Overcrowding Scale. A score calculated to estimate the degree of overcrowding (0-200 scale)."
                },
                {
                    "rowIndex": 10,
                    "Title": "OR: Operating Room"
                },
                {
                    "rowIndex": 12,
                    "Title": "PACU: Post-Anesthesia Care Unit. The recovery room where patients go after surgery."
                },
                {
                    "rowIndex": 14,
                    "Title": "FCOTS: First Case On Time Starts. A measure of efficiency ensuring the first surgeries of the day begin as scheduled."
                },
                {
                    "rowIndex": 16,
                    "Title": "SPD: Sterile Processing Department. The department responsible for cleaning and sterilizing surgical instruments."
                },
                {
                    "rowIndex": 18,
                    "Title": "EVS: Environmental Services. The housekeeping department responsible for cleaning rooms."
                },
                {
                    "rowIndex": 20,
                    "Title": "TAT: Turnaround Time. The time it takes to complete a process (e.g., cleaning a room between patients)."
                },
                {
                    "rowIndex": 22,
                    "Title": "OB: Obstetrics (Maternity care)."
                },
                {
                    "rowIndex": 24,
                    "Title": "Pyxis: An automated medication dispensing system (metric tracks stock-outs or errors)."
                }
            ],
